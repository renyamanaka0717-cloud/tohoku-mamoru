<!--
ios/App/App/Info.plist の <dict> 直下に追加するスニペット。

各 <key> の名前（sage, lilac...）はアプリ側の APP_ICONS id とそのまま対応させている
（src/app/page.tsx の setNativeAppIcon 呼び出しが id をそのまま渡す）。
CFBundleIconFiles の "AppIcon-Sage" などは、Xcodeで
Assets.xcassets を右クリック → New iOS App Icon (Alternate) で作成する
アイコンセット名と一致させること（先頭大文字のPascalCase）。
画像本体は native-ios/icons/ に用意済み。
mint はプライマリアイコン（既存のAppIcon）を流用するため、ここには含めない。
-->
<key>CFBundleIcons</key>
<dict>
  <key>CFBundleAlternateIcons</key>
  <dict>
    <key>sage</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Sage</string></array></dict>
    <key>lilac</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Lilac</string></array></dict>
    <key>rose</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Rose</string></array></dict>
    <key>dusty</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Dusty</string></array></dict>
    <key>apricot</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Apricot</string></array></dict>
    <key>greige</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Greige</string></array></dict>
    <key>charcoal</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Charcoal</string></array></dict>
    <key>mocha</key>
    <dict><key>CFBundleIconFiles</key><array><string>AppIcon-Mocha</string></array></dict>
  </dict>
</dict>
